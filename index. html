<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Youcef Merakchi</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: Arial, sans-serif;
}

/* خلفية متحركة */
body{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background: linear-gradient(270deg, #00c6ff, #0072ff, #8e2de2, #ff0080);
    background-size: 800% 800%;
    animation: gradientBG 10s ease infinite;
}

@keyframes gradientBG {
    0%{background-position:0% 50%;}
    50%{background-position:100% 50%;}
    100%{background-position:0% 50%;}
}

/* الكارد */
.card{
    background: rgba(0,0,0,0.3);
    padding:30px;
    border-radius:25px;
    text-align:center;
    color:white;
    width:320px;
    backdrop-filter: blur(10px);
}

/* العنوان */
h1{
    margin-bottom:10px;
}

p{
    margin-bottom:25px;
    color:#ddd;
}

/* الأزرار */
.btn{
    display:block;
    margin:15px 0;
    padding:15px;
    border-radius:30px;
    text-decoration:none;
    color:white;
    font-weight:bold;
    transition:0.3s;
}

/* ألوان الأزرار */
.discord{
    background: linear-gradient(45deg, #5865F2, #7289DA);
}

.instagram{
    background: linear-gradient(45deg, #f58529, #dd2a7b, #8134af);
}

.tiktok{
    background: linear-gradient(45deg, #25F4EE, #FE2C55, #000);
}

/* hover */
.btn:hover{
    transform:scale(1.05);
    opacity:0.9;
}

/* الفوتر */
.footer{
    margin-top:20px;
    font-size:12px;
    color:#ccc;
}

</style>
</head>

<body>

<div class="card">
    <h1>YOUCEF MERAKCHI</h1>
    <p>MY OFFICIAL ACCOUNT</p>

    <a class="btn discord" href="https://discord.com/users/cmx_29" target="_blank">
        Discord
    </a>

    <a class="btn instagram" href="https://instagram.com/le_couer_ee" target="_blank">
        Instagram
    </a>

    <a class="btn tiktok" href="https://tiktok.com/@dark_xx7x" target="_blank">
        TikTok
    </a>

    <div class="footer">
        © 2026 Youcef Merakchi — All Rights Reserved
    </div>
</div>

</body>
</html>
